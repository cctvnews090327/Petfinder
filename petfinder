local function dismissScreens()
    local pg = lp:WaitForChild("PlayerGui", 10); if not pg then return end
    local t0 = tick()
    while tick() - t0 < 20 do
        local loading = pg:FindFirstChild("LoadingGui")
        if loading then
            local frame = loading:FindFirstChild("Variant1Frame")
