                    task.wait(0.1)
                    vim:SendMouseButtonEvent(
                        workspace.CurrentCamera.ViewportSize.X / 2,
                        workspace.CurrentCamera.ViewportSize.Y * 0.65,
                        0, false, game, 0)
                end)
                task.wait(0.5)
            else task.wait(0.3) end
        else break end
        task.wait(0.3)
    end
end

local function waitForControl()
    setStatus("Dismissing screens...", C.muted)
    task.spawn(dismissScreens)
    local char = lp.Character or lp.CharacterAdded:Wait()
    local hum  = char:WaitForChild("Humanoid", 15);          if not hum then return false end
    local hrp  = char:WaitForChild("HumanoidRootPart", 15);  if not hrp then return false end
    local t0 = tick()
    while tick() - t0 < 20 do
        local st = hum:GetState()
        if st ~= Enum.HumanoidStateType.None
        and st ~= Enum.HumanoidStateType.Dead
        and hum.WalkSpeed > 0 then break end
        task.wait(0.3)
    end
    task.wait(1); return true
end

