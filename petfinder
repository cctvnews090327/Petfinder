                and frame.InnerFrame:FindFirstChild("PressAnyTxt")
            if pressAny and pressAny.Visible then
                local vim = game:GetService("VirtualInputManager")
                pcall(function()
                    vim:SendMouseButtonEvent(
                        workspace.CurrentCamera.ViewportSize.X / 2,
                        workspace.CurrentCamera.ViewportSize.Y * 0.65,
