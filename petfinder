local function shouldTame(refPart)
    local petName = refPart:GetAttribute("PetName") or ""
    local ownerID = refPart:GetAttribute("OwnerUserId")
    if not ownerID or ownerID ~= 0 then return false, nil end
    local petSize = refPart:GetAttribute("PetSize") or ""
    local petType = refPart:GetAttribute("PetType") or refPart:GetAttribute("Type") or ""
    local lower = petName:lower()
    if MUTATIONS[petSize] then return true, petSize .. " " .. petName end
    if petType == "Rainbow" and MUTATIONS["Rainbow"] then return true, "Rainbow " .. petName end
    if lower:find("big ") or lower:find("huge ") or lower:find("rainbow ") then return true, petName end
    if TARGETS[petName] then return true, petName end
    return false, nil
end

local function getMutationTier(refPart)
    local size = refPart:GetAttribute("PetSize") or ""
    if size == "Huge" then return 3 end
    if size == "Big"  then return 2 end
    if (refPart:GetAttribute("PetType") or "") == "Rainbow" then return 1 end
    return 0
end

local function getPriority(refPart)
    return PRIORITY[refPart:GetAttribute("PetName") or ""] or 99
end

local function findWildModel(refPart)
    local spawns = workspace.Map:FindFirstChild("WildPetSpawns")
    if not spawns then return nil end
    local uuid = refPart.Name:match("WildPet_(.+)$")
    if not uuid then return nil end
    for _, c in ipairs(spawns:GetChildren()) do
        if c.Name:find(uuid, 1, true) then return c end
    end
    return nil
end

local function findTamePrompt(model)
    if not model then return nil end
    local fallback
    for _, d in ipairs(model:GetDescendants()) do
        if d:IsA("ProximityPrompt") and d.Enabled then
            local at = (d.ActionText or "") .. " " .. (d.ObjectText or "")
            if at:lower():find("tame") then return d end
            fallback = fallback or d
        end
    end
    return fallback
end

-- =====================
-- TAME (HoldDuration-aware + anchored)
-- =====================
local function tamePet(refPart, displayName)
    taming = true
    emptyAt = nil
    countBg.Visible = false

    local price   = refPart:GetAttribute("Price") or 0
    local balance = getBalance()
    if balance < price then
        setStatus("Can't afford " .. displayName, C.muted)
        sendWebhook("⚠️ Insufficient Funds",
            "**Target:** " .. displayName ..
            "\n**Price:** " .. price ..
            "\n**Balance:** " .. balance ..
            "\n**Server:** " .. game.JobId:sub(1,8), 16744272)
        taming = false
        return false
    end

    setTarget(refPart, displayName)
    setStatus("TPing → " .. displayName, C.gold)

    local char = lp.Character
    local hrp  = char and char:FindFirstChild("HumanoidRootPart")
    local hum  = char and char:FindFirstChildOfClass("Humanoid")
    if not hrp or not hum then taming = false; return false end

    local model = findWildModel(refPart)
    local anchorPart = (model and model:FindFirstChild("RootPart")) or refPart
    local function anchorCFrame()
        if anchorPart and anchorPart.Parent then
            return CFrame.new(anchorPart.Position + Vector3.new(0, 4, 0))
        end
        return hrp.CFrame
    end

    local prevAnchored = hrp.Anchored
    local prevAutoRot  = hum.AutoRotate
    pcall(function() hum.PlatformStand = true end)
    pcall(function() hum.AutoRotate    = false end)
    pcall(function() lp.ReplicationFocus = lp.Character end)

    hrp.CFrame = anchorCFrame()
    task.wait(0.15)
    hrp.Anchored = true

    local stopHB = false
    local hbConn
    hbConn = RunService.Heartbeat:Connect(function()
        if stopHB then if hbConn then hbConn:Disconnect() end return end
        if not hrp.Parent then return end
        hrp.CFrame = anchorCFrame()
        local m = findWildModel(refPart)
        local p = findTamePrompt(m)
        if p and p.Parent and p.Parent:IsA("BasePart") then
            pcall(function() p.Parent.CFrame = hrp.CFrame end)
        end
    end)

    local success, sniped = false, false
    local conn = WildPetTameResult.OnClientEvent:Connect(function() success = true end)
    local snipeConn
    snipeConn = refPart:GetAttributeChangedSignal("OwnerUserId"):Connect(function()
        local newOwner = refPart:GetAttribute("OwnerUserId")
        if newOwner and newOwner ~= 0 then
            if newOwner == lp.UserId then success = true else sniped = true end
        end
    end)

    setStatus("Taming " .. displayName .. "...", C.gold)
    local t0 = tick()

    local lastPrompt, lastFireAt, lastHoldDur = nil, 0, 0

    while refPart.Parent and not success and not sniped and running do
        if tick() - t0 > TAME_TIMEOUT then break end

        local m = findWildModel(refPart)
        local prompt = findTamePrompt(m)

        if prompt then
            local hd = prompt.HoldDuration or 0
            local needFire = (prompt ~= lastPrompt)
                or (tick() - lastFireAt >= (lastHoldDur + 0.4))

            if needFire then
                -- Strategy A: zero hold locally, fire instantly
                local prevHold = prompt.HoldDuration
                pcall(function() prompt.HoldDuration = 0 end)
                pcall(function() fireproximityprompt(prompt) end)
                pcall(function() prompt.HoldDuration = prevHold end)

                lastPrompt  = prompt
                lastFireAt  = tick()
                lastHoldDur = hd

                -- Strategy B fallback: wait the real hold duration, then fire "release"
                local waitTime = math.max(hd, 0.2)
                local elapsed  = 0
                while elapsed < waitTime
                    and refPart.Parent and not success and not sniped and running do
                    task.wait(0.1)
                    elapsed = elapsed + 0.1
                    if refPart:GetAttribute("OwnerUserId") == lp.UserId then
                        success = true; break
                    end
                end

                if not success and not sniped and prompt.Parent then
                    pcall(function() fireproximityprompt(prompt) end)
                end
            else
                task.wait(0.2)
            end
        else
            pcall(function() WildPetTame:Fire(refPart) end)
            task.wait(0.3)
        end

        if refPart:GetAttribute("OwnerUserId") == lp.UserId then success = true end
    end

    stopHB = true
    if hbConn    then pcall(function() hbConn:Disconnect()    end) end
    if conn      then pcall(function() conn:Disconnect()      end) end
    if snipeConn then pcall(function() snipeConn:Disconnect() end) end
    pcall(function()
        hrp.Anchored      = prevAnchored
        hum.PlatformStand = false
        hum.AutoRotate    = prevAutoRot
    end)

    if success then
        local rarity = refPart:GetAttribute("Rarity") or "?"
        local size   = refPart:GetAttribute("PetSize") or "Normal"
        lastTamedLbl.Text = "Last: " .. displayName
        setStatus("✓ Tamed " .. displayName, C.accent)
        setTarget(nil, nil)
        sendWebhook("✅ Tamed — " .. displayName,
            "**Pet:** " .. (refPart:GetAttribute("PetName") or "?") ..
            "\n**Size:** " .. size ..
            "\n**Rarity:** " .. rarity ..
            "\n**Price:** " .. price ..
            "\n**Balance after:** " .. getBalance() ..
            "\n**Server:** " .. game.JobId:sub(1,8), 5763719)
        taming = false; return true
    elseif sniped then
        setStatus("Sniped — rescanning", C.muted)
        setTarget(nil, nil)
        sendWebhook("😞 Sniped — " .. displayName, "**Server:** " .. game.JobId:sub(1,8), 15548997)
        taming = false; return false
    else
        setStatus("Tame failed — rescanning", C.muted)
        setTarget(nil, nil)
        taming = false; return false
    end
end

local function collectTargets()
    local map = workspace:FindFirstChild("Map"); if not map then return {} end
    local ref = map:FindFirstChild("WildPetRef"); if not ref then return {} end
    local found = {}
    for _, v in ipairs(ref:GetChildren()) do
        local ok, displayName = shouldTame(v)
        if ok then table.insert(found, { part = v, display = displayName }) end
    end
    table.sort(found, function(a, b)
        local ma, mb = getMutationTier(a.part), getMutationTier(b.part)
        if ma ~= mb then return ma > mb end
        return getPriority(a.part) < getPriority(b.part)
    end)
    return found
end

-- =====================
-- SERVER HOP
-- =====================
local function hopServer()
    if not running then return end
    hopping = true; hopCancelled = false
    countBg.Visible = true
    for i = HOP_DELAY, 1, -1 do
        if hopCancelled or not running then
            countBg.Visible = false; hopping = false; return
        end
        countLbl.Text = "No targets — hopping in " .. i .. "s"
        countBar.Size = UDim2.new(i / HOP_DELAY, 0, 1, 0)
        setStatus("Hopping in " .. i .. "s — STOP to cancel", C.muted)
        task.wait(1)
    end
    if hopCancelled or not running then
        countBg.Visible = false; hopping = false; return
    end
    countBg.Visible = false
    setStatus("Hopping...", C.muted)

    local available = {}
    local mapRef = workspace:FindFirstChild("Map")
    if mapRef then
        local refFolder = mapRef:FindFirstChild("WildPetRef")
        if refFolder then
            for _, v in ipairs(refFolder:GetChildren()) do
                local petName = v:GetAttribute("PetName") or "?"
                local rarity  = v:GetAttribute("Rarity") or "?"
                local size    = v:GetAttribute("PetSize") or ""
                local pType   = v:GetAttribute("PetType") or ""
                local display = (size ~= "" and (size .. " ") or "")
                    .. (pType == "Rainbow" and "Rainbow " or "")
                    .. petName .. " [" .. rarity .. "]"
                table.insert(available, display)
            end
        end
    end
    if lastHopFrom ~= game.JobId then
        lastHopFrom = game.JobId
        sendWebhook("🔄 Server Hop",
            "**From:** " .. game.JobId:sub(1,8) ..
            "\n**Balance:** " .. getBalance() ..
            "\n**Pets in server:**\n" .. (#available > 0 and table.concat(available, "\n") or "None"),
            16776960)
    end

    if getgenv then
        local src = getgenv().__PETFINDER_SRC
        if src then
            local q = (syn and syn.queue_on_teleport)
                or (fluxus and fluxus.queue_on_teleport)
                or queue_on_teleport
            if q then pcall(q, src) end
        end
    end

    local tried = 0
    for attempt = 1, 10 do
        if not running then break end
        local ok, body = pcall(function()
            local url = ("https://games.roblox.com/v1/games/%d/servers/Public?sortOrder=Asc&limit=100"):format(placeId)
                .. (cursor ~= "" and ("&cursor=" .. cursor) or "")
            return HttpService:JSONDecode(game:HttpGet(url))
        end)
        if ok and body and body.data then
            cursor = body.nextPageCursor or ""
            for _, s in ipairs(body.data) do
                local hasRoom = s.playing and s.maxPlayers
                    and s.playing >= MIN_PLAYERS
                    and s.playing <= (s.maxPlayers - FULL_BUFFER)
                if hasRoom and s.id ~= game.JobId and not visited[s.id] then
                    visited[s.id] = true
                    if getgenv then getgenv().__PET_VISITED = visited end
                    tried = tried + 1
                    setStatus("TP try " .. tried .. " (" .. s.playing .. "/" .. s.maxPlayers .. ")", C.muted)
                    local tpOk = pcall(function()
                        TeleportService:TeleportToPlaceInstance(placeId, s.id, lp)
                    end)
                    if tpOk then
                        task.wait(6)
                        if not hopping then
                            hopping = true   -- TeleportInitFailed cleared it; try next
                        else
                            hopping = false
                            return
                        end
                    end
                    task.wait(0.5)
                end
            end
            if cursor == "" then
                visited = { [game.JobId] = true }
                cursor  = ""
            end
        end
        task.wait(1.5)
    end

    setStatus("All TPs failed — rejoin", C.danger)
    pcall(function() TeleportService:Teleport(placeId, lp) end)
    hopping = false
end

