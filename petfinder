do
    local UIS = game:GetService("UserInputService")
    local dragging, dragStart, startPos
    win.InputBegan:Connect(function(input)
        local touch = input.UserInputType == Enum.UserInputType.Touch
                   or input.UserInputType == Enum.UserInputType.MouseButton1
        if touch and (input.Position.Y - win.AbsolutePosition.Y) < 30 then
            dragging = true
            dragStart = input.Position
            startPos  = win.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.Touch
            or input.UserInputType == Enum.UserInputType.MouseMovement) then
            local d = input.Position - dragStart
            win.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + d.X,
                startPos.Y.Scale, startPos.Y.Offset + d.Y)
        end
    end)
end

local function mkFrame(parent, size, pos, color, radius)
    local f = Instance.new("Frame")
    f.Size = size; f.Position = pos
    f.BackgroundColor3 = color or C.panel
    f.BorderSizePixel = 0; f.Parent = parent
    if radius then local c = Instance.new("UICorner", f); c.CornerRadius = UDim.new(0, radius) end
    return f
end

